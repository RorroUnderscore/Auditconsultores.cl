RewriteEngine On

# --- Variables de entorno para BD / Admin ---
# Reemplaza estos valores por tus datos reales en cPanel.
SetEnv DB_CONNECTION mysql
SetEnv DB_HOST localhost
SetEnv DB_PORT 3306
SetEnv DB_DATABASE tupresen_audit360
SetEnv DB_USERNAME tupresen_audituser
SetEnv DB_PASSWORD CAMBIAR_PASSWORD
SetEnv ADMIN_DEFAULT_EMAIL admin@auditconsultores.cl
SetEnv ADMIN_DEFAULT_PASSWORD CAMBIAR_PASSWORD_ADMIN

# keep existing files/directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Admin and login routes for cPanel hosting
RewriteRule ^admin/?$ admin/index.php [L,QSA]
RewriteRule ^login/?$ admin/index.php [L,QSA]

# Public survey by token route
RewriteRule ^survey/([A-Za-z0-9_-]+)/?$ survey.php?token=$1 [L,QSA]
